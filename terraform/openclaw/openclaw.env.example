#
# Example configuration for the OpenClaw bootstrap script.
# Copy this file to `openclaw.env` and fill in real values.
#

user_id="123"
agent_id="my-agent-id"

# One of: openrouter, openai, anthropic
llm_provider="openrouter"

# Model name for your provider
llm_model="gpt-4.1-mini"

telegram_bot_token="YOUR_TELEGRAM_BOT_TOKEN"

# API key for the chosen LLM provider
api_key="YOUR_LLM_API_KEY"

# Shared secret for the OpenClaw gateway
gateway_token="GENERATE_A_SECURE_RANDOM_STRING"

subdomain="agent"
domain="example.com"
admin_email="you@example.com"

